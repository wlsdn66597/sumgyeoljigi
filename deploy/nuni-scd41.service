[Unit]
Description=NUNI SCD41 Reader (I2C CO2/temp/humidity -> sensor/env)
After=network-online.target mosquitto.service
Wants=network-online.target mosquitto.service

[Service]
Type=simple
User=sooin
WorkingDirectory=/home/sooin/sumgyeoljigi
ExecStart=/home/sooin/sumgyeoljigi/.venv/bin/python scd41_reader.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
