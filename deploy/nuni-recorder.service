[Unit]
Description=NUNI MQTT Recorder (raw JSONL for overnight experiments)
After=network-online.target mosquitto.service
Wants=network-online.target mosquitto.service

[Service]
Type=simple
User=sooin
WorkingDirectory=/home/sooin/sumgyeoljigi
ExecStart=/home/sooin/sumgyeoljigi/.venv/bin/python recorder.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
