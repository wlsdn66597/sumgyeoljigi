[Unit]
Description=NUNI Edge Node (sensors + cry + fusion, always-on)
After=network-online.target mosquitto.service
Wants=network-online.target mosquitto.service

[Service]
Type=simple
User=sooin
WorkingDirectory=/home/sooin/sumgyeoljigi
Environment=NUNI_BUS=mqtt
ExecStart=/home/sooin/sumgyeoljigi/.venv/bin/python edge_node.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
